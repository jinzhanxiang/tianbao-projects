<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
<title>天保控股项目管理中心 · 首页</title>
<meta name="description" content="天保控股项目管理系统 v3 · 首页 · 行业分布 + 行业最新动态">
<link rel="stylesheet" href="assets/tianbao.css">
<style>
/* === index.html 专属 · 首页美化 === */
:root {
  --gold: #B45309;
}
body{background:var(--bg);position:relative;overflow-x:hidden}
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 800px 400px at 10% 0%,rgba(192,57,43,0.05),transparent 60%),
    radial-gradient(ellipse 800px 400px at 90% 100%,rgba(21,101,192,0.05),transparent 60%),
    radial-gradient(circle at 50% 50%,rgba(180,83,9,0.02),transparent 70%);
}
.v3-home{max-width:1320px;margin:0 auto;padding:0 24px;position:relative;z-index:1}

/* === 大标题分级放大（核心品牌 > 一级标题 > 二级标题） === */
.nav-brand>div>div:first-child{
  font-family:var(--hei);
  font-size:26px!important;letter-spacing:2px!important;
  font-weight:900;
  background:linear-gradient(90deg,var(--ink) 0%,var(--seal) 60%,var(--gold) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;background-size:200% 100%;
  position:relative;animation:brandShine 4s ease-in-out infinite;
}
.nav-brand-sub{font-size:12px!important;font-weight:600!important;letter-spacing:.6px!important;color:var(--ink-2)!important;margin-top:2px}
.nav-brand-sub .clock{font-size:13px!important}
.nav-logo{width:42px!important;height:42px!important;font-size:16px!important}
.v3-section-h h2{font-size:24px!important;letter-spacing:5px!important}

/* === 概览标题 === */
.v3-section-h{display:flex;justify-content:space-between;align-items:center;margin:4px 0 4px;padding-bottom:4px;border-bottom:2px solid var(--ink);position:relative}
.v3-section-h::after{content:'';position:absolute;bottom:-2px;left:0;width:80px;height:2px;background:linear-gradient(90deg,var(--seal),transparent)}
.v3-section-h h2{font-family:var(--hei);font-size:20px;color:var(--ink);font-weight:900;margin:0;display:flex;align-items:center;gap:10px;letter-spacing:4px;position:relative}
.v3-section-h h2::before{content:'';width:5px;height:18px;background:linear-gradient(180deg,var(--doc-rule) 0%,var(--seal) 60%,var(--seal-2) 100%);border-radius:1px;box-shadow:0 0 8px rgba(192,57,43,0.4)}
.v3-section-h em{font-style:normal;font-family:var(--fsong);font-size:11px;color:var(--ink-2);font-weight:600;letter-spacing:.4px;display:flex;align-items:center;gap:6px}
.v3-section-h em::before{content:'';width:6px;height:6px;border-radius:50%;background:#16A34A;box-shadow:0 0 0 3px rgba(22,163,74,0.2);animation:livePulse 2s ease-in-out infinite}
@keyframes livePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}

/* === 项目概况汇总 · 行业·项目分布 一体化全息面板（v3.5 精简版） === */
.v3-holo{
  position:relative;background:linear-gradient(180deg,var(--paper) 0%,var(--paper-2) 100%);
  border:1px solid var(--border);border-radius:14px;padding:4px 12px 5px;margin-bottom:2px;
  box-shadow:0 4px 14px rgba(0,0,0,.06),inset 0 0 0 1px rgba(124,58,237,.05);
  display:flex;flex-direction:column;gap:3px;overflow:hidden;
}
.v3-holo::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:linear-gradient(180deg,var(--doc-rule) 0%,var(--seal) 50%,var(--seal-2) 100%);border-radius:14px 0 0 14px}
.v3-holo::after{content:'';position:absolute;left:0;right:0;top:0;height:2px;background:repeating-linear-gradient(90deg,#7C3AED 0 12px,transparent 12px 24px);opacity:.4;animation:holoScan 3.5s linear infinite}
@keyframes holoScan{from{transform:translateX(0)}to{transform:translateX(-24px)}}

.v3-holo-head{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:0 0 2px;border-bottom:1px solid var(--border);position:relative}
.v3-holo-head h2{font-family:var(--hei);font-size:18px;color:var(--ink);font-weight:900;margin:0;letter-spacing:4px;display:flex;align-items:center;gap:8px;line-height:1}
.v3-holo-head h2::before{content:'◆';font-size:16px;color:#7C3AED;filter:drop-shadow(0 0 6px rgba(124,58,237,.6));animation:lightningPulse 1.8s ease-in-out infinite}
@keyframes lightningPulse{0%,100%{transform:scale(1) rotate(0);opacity:1}50%{transform:scale(1.15) rotate(60deg);opacity:.85}}
.v3-holo-head em{font-style:normal;font-family:ui-monospace,monospace;font-size:11px;color:var(--ink-2);font-weight:700;letter-spacing:1px;display:flex;align-items:center;gap:8px}
.v3-holo-head em::before{content:'';width:7px;height:7px;border-radius:50%;background:#16A34A;box-shadow:0 0 8px #16A34A;animation:holoLivePulse 1.5s ease-in-out infinite}
@keyframes holoLivePulse{0%,100%{box-shadow:0 0 8px #16A34A}50%{box-shadow:0 0 16px #16A34A,0 0 4px #16A34A}}

/* === 单列布局：上方 4-指标条 + 下方雷达 + 右侧行业分布条 === */
.v3-holo-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:10px;align-items:stretch;min-height:170px}

/* === 上方 4-指标数据条（项目总数 / 行业 / 报告 / 平均进度） === */
.v3-holo-pulse{
  display:grid;grid-template-columns:repeat(4,1fr);gap:8px;
  padding:2px 4px;border-bottom:1px dashed var(--border);margin-bottom:2px;
}
.v3-holo-stat{position:relative;padding:4px 4px 3px;text-align:center;border-radius:8px;background:linear-gradient(180deg,rgba(255,255,255,.4) 0%,transparent 100%);transition:.3s;overflow:hidden}
.v3-holo-stat::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:60%;height:2px;background:var(--hc,#7C3AED);box-shadow:0 0 8px var(--hc,#7C3AED);border-radius:1px}
.v3-holo-stat-big{font-family:var(--hei);font-size:22px;font-weight:900;color:var(--hc,#7C3AED);line-height:1;letter-spacing:-1.5px;position:relative;display:block;animation:numGlow 2.4s ease-in-out infinite;transition:transform .35s}
@keyframes numGlow{0%,100%{text-shadow:0 0 0 transparent}50%{text-shadow:0 0 14px var(--hc-glow,rgba(124,58,237,.5)),0 0 4px var(--hc-glow,rgba(124,58,237,.3))}}
.v3-holo-stat:hover .v3-holo-stat-big{transform:scale(1.08)}
.v3-holo-stat-lbl{font-family:var(--hei);font-size:11px;color:var(--ink-2);font-weight:700;letter-spacing:3px;margin-top:3px;display:block}

/* === 左：RADAR 主舞台 === */
.v3-holo-radar-stage{
  position:relative;display:flex;align-items:center;gap:10px;
  padding:6px 8px 6px 12px;
  border-left:3px solid #7C3AED;
  background:linear-gradient(135deg,rgba(124,58,237,.04) 0%,rgba(168,85,247,.02) 100%);
  border-radius:0 8px 8px 0;
  min-width:0;
}
.v3-holo-radar-h{position:absolute;top:4px;left:14px;font-family:var(--hei);font-size:12px;color:#7C3AED;font-weight:800;letter-spacing:3px}
.v3-holo-radar-h em{font-style:normal;font-family:ui-monospace,monospace;font-size:10px;color:var(--ink-3);font-weight:600;background:var(--paper);padding:1px 6px;border-radius:8px;margin-left:6px}
.v3-holo-radar{position:relative;width:170px;height:140px;flex-shrink:0;margin-left:auto}
.v3-holo-radar svg{width:100%;height:100%;overflow:visible}
.radar-grid{fill:none;stroke:var(--border);stroke-width:.5;stroke-dasharray:2 2;opacity:.5}
.radar-axis{stroke:var(--border);stroke-width:.5;opacity:.4}
.radar-poly{fill:url(#radar-grad);fill-opacity:.45;stroke:#7C3AED;stroke-width:1.8;filter:drop-shadow(0 0 6px rgba(124,58,237,.7));transform:scale(0);transform-origin:60px 50px;animation:radarPolyDraw 1.2s cubic-bezier(.4,.2,.2,1) forwards}
.radar-vtx{fill:#7C3AED;opacity:1;transform:scale(0);transform-origin:center;animation:vertexPop .6s cubic-bezier(.34,1.56,.64,1) forwards}
@keyframes vertexPop{from{transform:scale(0);opacity:0}60%{transform:scale(1.4);opacity:1}to{transform:scale(1);opacity:1}}
.radar-vtx-ring{fill:none;stroke:#7C3AED;stroke-width:1;opacity:0;animation:vertexRing 1.8s ease-out infinite}
@keyframes vertexRing{0%{r:1.5;opacity:.8}100%{r:8;opacity:0}}
.radar-label{font-family:var(--hei);font-size:7px;font-weight:800;fill:var(--ink);letter-spacing:.2px}
.radar-scan{fill:#7C3AED;opacity:.4;animation:radarSweep 4s linear infinite;transform-origin:60px 50px}
@keyframes radarSweep{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

/* === 右：行业分布条形图 === */
.v3-holo-bars-stage{
  display:flex;flex-direction:column;gap:3px;padding:6px 4px 6px 10px;
  border-left:1px dashed var(--border);
  background:linear-gradient(180deg,rgba(124,58,237,.02) 0%,transparent 100%);
  border-radius:0 8px 8px 0;
  min-width:0;overflow:hidden;
}
.v3-holo-bars-h{font-family:var(--hei);font-size:12px;color:#7C3AED;font-weight:800;letter-spacing:3px;display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;padding-bottom:3px;border-bottom:1px solid var(--border)}
.v3-holo-bars-h em{font-style:normal;font-family:ui-monospace,monospace;font-size:10px;color:var(--ink-3);font-weight:600}
.v3-holo-bar-row{display:grid;grid-template-columns:60px 1fr 22px;gap:6px;align-items:center;font-family:var(--fsong);font-size:11px;color:var(--ink-2);font-weight:600;line-height:1.3;padding:1px 0}
.v3-holo-bar-row .nm{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:var(--hei);font-size:11px;font-weight:700;letter-spacing:1px;color:var(--ink)}
.v3-holo-bar-row .bar{position:relative;height:7px;background:var(--bg-2);border-radius:4px;overflow:hidden;box-shadow:inset 0 1px 1px rgba(0,0,0,.06)}
.v3-holo-bar-row .bar i{display:block;height:100%;background:linear-gradient(90deg,var(--bc,#7C3AED),var(--bc-2,#A855F7));border-radius:4px;width:0;transition:width 1.2s cubic-bezier(.4,.2,.2,1);position:relative;box-shadow:0 0 6px var(--bc-glow,rgba(124,58,237,.4))}
.v3-holo-bar-row .bar i::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,.5) 50%,transparent 100%);background-size:200% 100%;animation:shineFlow 2.6s linear infinite}
@keyframes shineFlow{from{background-position:200% 0}to{background-position:-200% 0}}
.v3-holo-bar-row .cnt{font-family:ui-monospace,monospace;color:#7C3AED;font-weight:900;font-size:12px;text-align:right;text-shadow:0 0 6px rgba(124,58,237,.4)}

/* === 旧 KPI 类样式 · 已废弃（display:none 兜底） === */
.v3-kpi-grid,.v3-kpi,.v3-kpi-eyebrow,.v3-kpi-num-row,.v3-kpi-num,.v3-kpi-num-unit,.v3-kpi-num-ts,.v3-kpi-rows,.v3-kpi-row,.v3-kpi-meta,.v3-holo-core,.v3-holo-stages,.v3-holo-stages-h,.v3-holo-stage-bar,.v3-holo-stage-legend,.v3-holo-block,.v3-holo-donut-wrap,.v3-holo-donut,.v3-holo-donut-center,.v3-holo-donut-seg,.v3-holo-donut-bg{display:none}

/* === 3 类入口 · 极简单行结构 === */
.v3-entries{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin:2px 0 2px}
.v3-entry{
  background:linear-gradient(160deg,var(--paper) 0%,var(--paper-2) 100%);
  border:1px solid var(--border);border-radius:12px;padding:3px 11px 4px;
  cursor:pointer;transition:.3s cubic-bezier(.2,.8,.2,1);
  position:relative;overflow:hidden;display:block;text-decoration:none;color:inherit;
  box-shadow:0 2px 6px rgba(0,0,0,0.03);
}
.v3-entry::before{content:'';position:absolute;left:0;top:0;bottom:0;width:5px;background:linear-gradient(180deg,var(--cat-color,var(--seal)) 0%,var(--cat-color-2,var(--seal-2)) 100%);transition:.3s}
.v3-entry:hover{transform:translateY(-3px);box-shadow:0 8px 22px rgba(0,0,0,0.1),0 2px 6px var(--cat-color,var(--seal));border-color:var(--cat-color,var(--seal))}
.v3-entry:hover::before{width:8px;box-shadow:0 0 10px var(--cat-color,var(--seal))}
.v3-entry-row1{display:flex;align-items:center;gap:8px;margin-bottom:2px}
.v3-entry-icon{
  font-size:16px;line-height:1;display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;
  background:linear-gradient(135deg,var(--cat-color,var(--seal)) 0%,var(--cat-color-2,var(--seal-2)) 100%);
  border-radius:6px;color:#fff;filter:drop-shadow(0 2px 3px rgba(0,0,0,0.15));
  transition:.3s;flex-shrink:0;
}
.v3-entry:hover .v3-entry-icon{transform:rotate(-6deg) scale(1.08)}
.v3-entry-title{font-family:var(--hei);font-size:16px;color:var(--ink);font-weight:900;letter-spacing:3px;flex:1;min-width:0}
.v3-entry-count{font-family:ui-monospace,monospace;font-size:14px;color:var(--cat-color,var(--seal));font-weight:900;flex-shrink:0;letter-spacing:-.3px}
.v3-entry-count small{font-family:var(--fsong);font-size:10px;color:var(--ink-3);font-weight:700;letter-spacing:1px;margin-left:2px}
.v3-entry-meta{font-family:var(--fsong);font-size:10px;color:var(--ink-2);font-weight:600;line-height:1.3;letter-spacing:.2px;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.v3-entry-meta b{font-family:ui-monospace,monospace;color:var(--ink);font-weight:900}
.v3-entry-meta .sep{color:var(--border-strong);opacity:.4}
.v3-entry-meta .ind-chip{display:inline-flex;align-items:center;gap:3px;padding:1px 6px;background:rgba(0,0,0,.04);border-radius:6px;font-weight:700;color:var(--cat-color);font-size:10px}
.v3-entry-arrow{position:absolute;right:10px;bottom:8px;font-size:11px;color:var(--cat-color);font-weight:700;letter-spacing:.5px;opacity:0;transition:.3s}
.v3-entry:hover .v3-entry-arrow{opacity:1;transform:translateX(2px)}

/* === v3-entry-body / ring / chips 系列已废弃 · meta 单行内联 === */

/* === 行业分布 · 筛选条 === */
.v3-cloud-strip{
  display:flex;align-items:center;gap:10px;
  background:linear-gradient(90deg,var(--paper) 0%,var(--paper-2) 100%);
  border:1px solid var(--border);border-radius:12px;padding:4px 14px;margin:3px 0;
  box-shadow:0 2px 6px rgba(0,0,0,0.03);
}
.v3-cloud-strip .lbl{font-family:var(--hei);font-size:13px;color:var(--ink);font-weight:900;letter-spacing:3px;flex-shrink:0;padding-right:12px;border-right:2px solid var(--seal);display:flex;align-items:center;gap:6px}
.v3-cloud-strip .lbl::before{content:'';width:4px;height:14px;background:linear-gradient(180deg,var(--doc-rule),var(--seal));border-radius:1px}
.v3-cloud-strip .v3-cloud-tags{display:flex;flex-wrap:wrap;gap:5px;flex:1;min-width:0}

.v3-cloud-tag{
  display:inline-flex;align-items:center;gap:6px;padding:3px 12px;
  background:var(--bg-2);border:1px solid var(--border);border-radius:14px;
  font-family:var(--fsong);color:var(--ink-2);cursor:pointer;
  transition:.2s;font-weight:700;font-size:14px;
}
.v3-cloud-tag:hover{background:var(--paper);color:var(--ink);border-color:var(--seal);transform:translateY(-1px);box-shadow:0 2px 6px rgba(0,0,0,.08)}
.v3-cloud-tag.active{background:linear-gradient(135deg,var(--seal) 0%,var(--seal-2) 100%);color:#fff;border-color:var(--seal);box-shadow:0 2px 8px rgba(192,57,43,0.3)}
.v3-cloud-tag.active .count{color:#fff;font-weight:800}
.v3-cloud-tag .count{font-family:ui-monospace,monospace;font-weight:800;color:var(--seal);font-size:12px;background:rgba(192,57,43,0.1);padding:0 7px;border-radius:10px;min-width:22px;text-align:center}
.v3-cloud-tag-cloud{font-size:14px;font-weight:800;padding:4px 14px}
.v3-cloud-tag-cloud .count{background:rgba(0,0,0,.08);color:var(--ink-2)}
.v3-cloud-tag-cloud.active .count{background:rgba(255,255,255,.25);color:#fff}
.v3-cloud-empty{padding:6px 10px;color:var(--ink-3);font-family:var(--fsong);font-size:13px}

/* === 双栏滚动流 === */
.v3-feed2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:4px 0 8px}

/* === 近期动态时间线 · 填充空白 === */
.v3-timeline{
  background:linear-gradient(180deg,var(--paper) 0%,var(--paper-2) 100%);
  border:1px solid var(--border);border-radius:12px;padding:3px 14px 4px;
  box-shadow:0 2px 6px rgba(0,0,0,.04);
  position:relative;overflow:hidden;margin:2px 0 2px;
}
.v3-timeline::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--blue) 0%,var(--seal) 60%,var(--gold) 100%);opacity:.7}
.v3-timeline-head{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:3px;padding-bottom:3px;border-bottom:1px dashed var(--border)}
.v3-timeline-head h3{font-family:var(--hei);font-size:12px;color:var(--ink);font-weight:900;margin:0;display:flex;align-items:center;gap:6px;letter-spacing:2px}
.v3-timeline-head h3::before{content:'';width:4px;height:12px;background:linear-gradient(180deg,var(--blue),var(--seal));border-radius:1px}
.v3-timeline-head em{font-style:normal;font-family:ui-monospace,monospace;font-size:10px;color:var(--ink-3);font-weight:600;letter-spacing:.5px}
.v3-timeline-track{
  display:flex;flex-wrap:nowrap;gap:10px;overflow-x:auto;overflow-y:hidden;
  padding-bottom:4px;
  scrollbar-width:thin;scrollbar-color:var(--border) transparent;
}
.v3-timeline-track::-webkit-scrollbar{height:4px}
.v3-timeline-track::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.v3-tl-card{
  flex:0 0 auto;width:140px;background:var(--bg-2);
  border:1px solid var(--border);border-left:3px solid var(--tl-c,var(--blue));
  border-radius:8px;padding:3px 7px 4px;
  font-family:var(--fsong);position:relative;overflow:hidden;
  transition:.2s;text-decoration:none;color:inherit;
}
.v3-tl-card:hover{background:var(--paper);border-left-width:5px;transform:translateY(-2px);box-shadow:0 4px 10px rgba(0,0,0,.08)}
.v3-tl-top{display:flex;justify-content:space-between;align-items:center;font-size:9px;color:var(--ink-3);font-family:ui-monospace,monospace;font-weight:800;letter-spacing:1px;margin-bottom:0}
.v3-tl-stage{font-family:var(--hei);font-size:11px;color:var(--tl-c,var(--blue));font-weight:900;line-height:1.25;margin:0 0 1px;letter-spacing:.3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.v3-tl-meta{font-size:9px;color:var(--ink-3);display:flex;gap:4px;align-items:center;flex-wrap:wrap;margin-top:1px}
.v3-tl-meta b{font-family:ui-monospace,monospace;color:var(--ink);font-weight:900;font-size:11px}
.v3-tl-meta i{font-style:normal;padding:1px 5px;background:rgba(0,0,0,.04);border-radius:4px;font-weight:700;color:var(--ink-2)}
.v3-feed{
  background:linear-gradient(180deg,var(--paper) 0%,var(--paper-2) 100%);
  border:1px solid var(--border);border-radius:12px;padding:6px 12px 8px;
  display:flex;flex-direction:column;min-width:0;min-height:0;
  box-shadow:0 2px 6px rgba(0,0,0,0.04);
  position:relative;overflow:hidden;
}
.v3-feed::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--feed-color,var(--blue)) 0%,transparent 100%)}
.v3-feed-head{display:flex;align-items:center;gap:8px;margin-bottom:5px;padding-bottom:5px;border-bottom:1px solid var(--border)}
.v3-feed-head h2{font-family:var(--hei);font-size:15px;color:var(--ink);font-weight:900;margin:0;display:flex;align-items:center;gap:8px;letter-spacing:2px}
.v3-feed-head h2::before{content:'';width:4px;height:14px;background:linear-gradient(180deg,var(--doc-rule),var(--seal));border-radius:1px}
.v3-feed-head small{margin-left:auto;font-size:11px;color:var(--ink-3);font-family:var(--fsong);display:flex;align-items:center;gap:4px}
.v3-feed-head small::before{content:'';width:5px;height:5px;border-radius:50%;background:#16A34A;box-shadow:0 0 0 2px rgba(22,163,74,0.2);animation:livePulse 2s ease-in-out infinite}

.v3-marquee{position:relative;height:200px;overflow:hidden;-webkit-mask-image:linear-gradient(180deg,transparent 0,#000 6%,#000 94%,transparent 100%);mask-image:linear-gradient(180deg,transparent 0,#000 6%,#000 94%,transparent 100%)}
.v3-marquee-track{display:flex;flex-direction:column;animation:marqueeUp var(--dur,32s) linear infinite;will-change:transform}
.v3-marquee:hover .v3-marquee-track{animation-play-state:paused}
.v3-marquee.no-scroll .v3-marquee-track{animation:none}
@keyframes marqueeUp{from{transform:translateY(0)}to{transform:translateY(-50%)}}

.v3-feed-card{
  display:flex;flex-direction:column;gap:2px;background:var(--bg-2);
  border:1px solid var(--border);border-left:3px solid var(--feed-color,var(--blue));
  border-radius:6px;padding:5px 10px;margin-bottom:4px;
  text-decoration:none;color:inherit;transition:.2s;flex-shrink:0;
}
.v3-feed-card:hover{background:var(--paper);border-left-width:5px;box-shadow:0 4px 12px rgba(0,0,0,.08);transform:translateX(2px)}
.v3-feed-card-top{display:flex;align-items:center;gap:8px}
.v3-feed-tag{font-size:10px;color:var(--feed-color,var(--blue));background:rgba(21,101,192,0.1);padding:1px 8px;border-radius:10px;font-weight:800;letter-spacing:1px;line-height:1.4}
.v3-feed-date{font-family:ui-monospace,monospace;font-size:11px;color:var(--seal);font-weight:800;letter-spacing:1px;margin-left:auto;flex-shrink:0}
.v3-feed-title{font-family:var(--fsong);font-size:13px;color:var(--ink);font-weight:700;line-height:1.45;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;letter-spacing:.2px}
.v3-feed-card:hover .v3-feed-title{color:var(--seal)}
.v3-feed-sub{font-size:11px;color:var(--ink-3);font-family:var(--fsong);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:flex;align-items:center;gap:4px}
.v3-feed-empty{padding:40px 12px;text-align:center;color:var(--ink-3);font-family:var(--fsong);font-size:13px;text-indent:0}

.v3-loading{padding:60px;text-align:center;color:var(--ink-3);font-family:var(--fsong);font-size:14px;text-indent:0}
.v3-loading::before{content:'';display:inline-block;width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--seal);border-radius:50%;animation:spin 1s linear infinite;margin-right:8px;vertical-align:-2px}
@keyframes spin{to{transform:rotate(360deg)}}

/* === 卡片入场动画 === */
@keyframes cardIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.v3-kpi,.v3-entry,.v3-feed,.v3-cloud-strip{animation:cardIn .5s cubic-bezier(.2,.8,.2,1) backwards}
.v3-kpi:nth-of-type(1){animation-delay:.05s}
.v3-kpi:nth-of-type(2){animation-delay:.1s}
.v3-kpi:nth-of-type(3){animation-delay:.15s}
.v3-kpi:nth-of-type(4){animation-delay:.2s}
.v3-entry:nth-of-type(1){animation-delay:.15s}
.v3-entry:nth-of-type(2){animation-delay:.2s}
.v3-entry:nth-of-type(3){animation-delay:.25s}

@media (max-width:1100px){
  .v3-entries{grid-template-columns:1fr 1fr}
  .v3-feed2{grid-template-columns:1fr}
  .v3-kpi-grid{grid-template-columns:repeat(2,1fr)}
}
/* === 1100+ 宽度 + 短视口（1366×768 等） · 压紧整体 === */
@media (min-width:1100px) and (max-height:820px){
  .v3-timeline{padding:2px 14px 3px;margin:2px 0 2px;border-radius:10px}
  .v3-timeline-head{margin-bottom:2px;padding-bottom:3px}
  .v3-tl-card{width:135px;padding:3px 6px 4px}
  .v3-tl-stage{font-size:10px}
  .v3-tl-meta{font-size:8px}
  .v3-holo{padding:3px 12px 4px;gap:2px}
  .v3-holo-head{padding-bottom:1px}
  .v3-holo-head h2{font-size:15px}
  .v3-holo-head em{font-size:10px}
  .v3-holo-pulse{padding:2px 4px;margin-bottom:2px;gap:6px}
  .v3-holo-stat{padding:2px 3px 1px}
  .v3-holo-stat-big{font-size:20px}
  .v3-holo-stat-lbl{font-size:9px;letter-spacing:1px}
  .v3-holo-grid{min-height:90px;gap:8px}
  .v3-holo-radar{width:110px;height:88px}
  .v3-holo-radar-h{font-size:11px;letter-spacing:2px}
  .v3-holo-radar-h em{font-size:9px;padding:1px 5px}
  .v3-holo-bars-h{font-size:11px;padding-bottom:1px}
  .v3-holo-bar-row{font-size:9px;gap:4px}
  .v3-holo-bar-row .nm{font-size:10px}
  .v3-holo-bar-row .cnt{font-size:11px}
  .v3-holo-bar-row .bar{height:6px}
  .v3-marquee{height:170px}
  .v3-cloud-strip{padding:3px 14px;margin:2px 0}
  .v3-cloud-tag{padding:2px 9px;font-size:12px}
  .v3-cloud-tag-cloud{font-size:12px;padding:3px 12px}
  .v3-entries{margin:2px 0;gap:5px}
  .v3-entry{padding:3px 11px 4px}
  .v3-entry-icon{width:24px;height:24px;font-size:15px}
  .v3-entry-row1{margin-bottom:1px}
  .v3-section-h h2{font-size:16px;letter-spacing:2px}
  .v3-section-h{margin:2px 0}
  .v3-feed-head h2{font-size:13px;letter-spacing:2px;margin-bottom:3px}
  .v3-feed{padding:5px 10px 6px}
  .v3-feed-card{padding:4px 9px;margin-bottom:3px;gap:2px}
  .v3-feed-title{font-size:12px;line-height:1.35}
  .v3-home{padding:0 18px}
}
/* === 1000-1100 宽度 + 短视口 · 强制 entries 单行 + cloud 横排 === */
@media (min-width:760px) and (max-width:1099px) and (max-height:820px){
  .v3-entries{grid-template-columns:repeat(3,1fr)}
  .v3-feed2{grid-template-columns:1fr 1fr}
  .v3-timeline{padding:1px 12px 1px;margin:0;border-radius:8px}
  .v3-timeline::before{height:1px}
  .v3-timeline-head{margin-bottom:0;padding-bottom:1px;display:none}
  .v3-tl-card{padding:1px 6px 2px;width:120px}
  .v3-tl-stage{margin:0;font-size:10px}
  .v3-tl-meta{display:none}
  .v3-holo{padding:2px 10px 2px;gap:2px}
  .v3-holo-grid{min-height:78px;gap:6px}
  .v3-holo-pulse{padding:1px 4px;margin-bottom:0}
  .v3-holo-stat{padding:1px 3px 0;line-height:1}
  .v3-holo-stat-big{font-size:18px}
  .v3-holo-stat-lbl{font-size:8px;letter-spacing:1px;margin-top:1px}
  .v3-holo-radar{width:90px;height:70px}
  .v3-holo-bars-h{font-size:10px;padding-bottom:1px}
  .v3-holo-bar-row{font-size:9px;gap:3px;padding:0}
  .v3-holo-bar-row .nm{font-size:9px}
  .v3-holo-bar-row .cnt{font-size:10px}
  .v3-holo-bar-row .bar{height:4px}
  .v3-holo-head h2{font-size:13px}
  .v3-holo-head em{font-size:9px}
  .v3-holo-head{padding-bottom:1px}
  .v3-marquee{height:160px}
  .v3-cloud-strip{padding:2px 12px;margin:0}
  .v3-cloud-tag{padding:1px 8px;font-size:11px}
  .v3-cloud-tag .count{font-size:10px;padding:0 5px;min-width:16px}
  .v3-cloud-tag-cloud{font-size:12px;padding:2px 11px}
  .v3-entries{margin:1px 0}
  .v3-entry{padding:3px 9px 4px;gap:4px}
  .v3-entry-row1{margin-bottom:1px}
  .v3-feed-head h2{font-size:12px;letter-spacing:1px;margin-bottom:1px}
  .v3-feed{padding:3px 9px 4px}
  .v3-feed-card{padding:3px 8px 4px;margin-bottom:2px;gap:1px}
  .v3-feed-card .row1{font-size:11px}
  .v3-section-h h2{font-size:14px;letter-spacing:2px}
  .v3-section-h{margin:1px 0}
}
@media (max-width:760px){
  .v3-entries{grid-template-columns:1fr}
  .v3-feed2{grid-template-columns:1fr}
  .v3-kpi-grid{grid-template-columns:1fr 1fr}
  .v3-marquee{height:170px}
  .v3-section-h h2{font-size:18px;letter-spacing:2px}
}
/* === 短视口 · 高度 < 800 的紧凑模式（移动端/小窗） === */
@media (max-height:820px){
  /* 项目概况汇总紧凑 */
  .v3-holo{padding:3px 10px 4px;gap:3px}
  .v3-holo-head h2{font-size:15px;letter-spacing:3px}
  .v3-holo-head em{font-size:10px}
  .v3-holo-grid{min-height:100px;gap:8px}
  .v3-holo-stat{padding:3px 3px 2px}
  .v3-holo-stat-big{font-size:20px}
  .v3-holo-stat-lbl{font-size:9px;letter-spacing:2px}
  .v3-holo-radar{width:110px;height:88px}
  .v3-holo-radar-h{font-size:10px;letter-spacing:2px}
  .v3-holo-radar-h em{font-size:9px;padding:1px 5px}
  .v3-holo-bars-h{font-size:10px;letter-spacing:2px;padding-bottom:2px}
  .v3-holo-bar-row{font-size:9px;gap:4px;padding:0}
  .v3-holo-bar-row .nm{font-size:9px;letter-spacing:.5px}
  .v3-holo-bar-row .cnt{font-size:10px}
  .v3-holo-bar-row .bar{height:5px}
  /* 时间线紧凑 */
  .v3-timeline{padding:2px 12px 3px;margin:1px 0 2px}
  .v3-timeline-head h3{font-size:11px}
  .v3-timeline-head{margin-bottom:2px;padding-bottom:2px}
  .v3-tl-card{width:130px;padding:3px 6px 4px}
  .v3-tl-stage{font-size:10px}
  .v3-tl-meta{font-size:8px}
  /* 其他 */
  .v3-entries{gap:5px;margin:1px 0 1px}
  .v3-entry{padding:4px 10px 5px}
  .v3-entry-icon{width:22px;height:22px;font-size:14px}
  .v3-entry-title{font-size:13px;letter-spacing:2px}
  .v3-entry-count{font-size:12px}
  .v3-entry-meta{font-size:9px;gap:3px}
  .v3-cloud-strip{padding:3px 12px;margin:1px 0}
  .v3-cloud-strip .lbl{font-size:12px}
  .v3-cloud-tag{padding:2px 9px;font-size:13px}
  .v3-cloud-tag-cloud{font-size:13px}
  .v3-cloud-tag .count{font-size:11px;padding:0 6px;min-width:18px}
  /* 双栏滚动流紧凑 · 拉长（确保显示更多） */
  .v3-feed2{margin:2px 0 4px;gap:8px}
  .v3-feed{padding:4px 10px 5px}
  .v3-feed-head h2{font-size:13px;letter-spacing:2px;margin-bottom:2px}
  .v3-marquee{height:190px}
  .v3-feed-card{padding:4px 9px;margin-bottom:3px;gap:2px}
  .v3-feed-title{font-size:12px;line-height:1.35}
  .v3-feed-tag{font-size:9px;padding:0 6px}
  .v3-feed-date{font-size:10px}
  .v3-feed-summary{font-size:11px;line-height:1.45;-webkit-line-clamp:2}
  .v3-section-h h2{font-size:16px;letter-spacing:3px}
  .v3-section-h{margin:2px 0}
}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-brand" href="index.html">
      <div class="nav-logo">保</div>
      <div>
        <div>天保控股投资部 · 项目管理中心</div>
        <div class="nav-brand-sub">项目分类 · 行业动态 · 研究报告 一站式管理<span class="sep">·</span><span class="clock" id="navClock">--:--:--</span><span class="sep">·</span><span id="navDate">----年--月--日</span></div>
      </div>
    </a>
    <div class="nav-links">
      <a class="active">🏛 首页</a>
      <a href="page.html">📂 分类矩阵</a>
      <a href="all_reports.html">📚 所有报告</a>
    </div>
  </div>
</nav>

<div class="v3-home viewport-fit v3-grow">

  <!-- 项目概况汇总 · 行业·项目分布 一体化全息面板（v3.5 精简版） -->
  <div class="v3-holo" id="holoPanel">
    <div class="v3-holo-head">
      <h2>项目概况汇总</h2>
      <em id="holoMeta">实时同步 · 数据自动刷新</em>
    </div>
    <!-- 上方 4-指标数据条 -->
    <div class="v3-holo-pulse">
      <div class="v3-holo-stat" style="--hc:#C0392B;--hc-glow:rgba(192,57,43,.5)">
        <span class="v3-holo-stat-big" id="holoProjects" data-counter-up="0">0</span>
        <span class="v3-holo-stat-lbl">项目</span>
      </div>
      <div class="v3-holo-stat" style="--hc:#1565C0;--hc-glow:rgba(21,101,192,.5)">
        <span class="v3-holo-stat-big" id="holoReports" data-counter-up="0">0</span>
        <span class="v3-holo-stat-lbl">报告</span>
      </div>
      <div class="v3-holo-stat" style="--hc:#7C3AED;--hc-glow:rgba(124,58,237,.5)">
        <span class="v3-holo-stat-big" id="holoInds" data-counter-up="0">0</span>
        <span class="v3-holo-stat-lbl">行业</span>
      </div>
      <div class="v3-holo-stat" style="--hc:#B45309;--hc-glow:rgba(180,83,9,.5)">
        <span class="v3-holo-stat-big" id="holoProgress" data-counter-up="0">0</span>
        <span class="v3-holo-stat-lbl">平均进度%</span>
      </div>
    </div>
    <!-- 下方主舞台：左雷达 + 右行业条形图 -->
    <div class="v3-holo-grid">
      <!-- 左：行业分布雷达 -->
      <div class="v3-holo-radar-stage">
        <div class="v3-holo-radar-h">🎯 行业·项目雷达<em id="holoRadarTotal">—</em></div>
        <div class="v3-holo-radar">
          <svg viewBox="0 0 120 100" preserveAspectRatio="xMidYMid meet">
            <defs>
              <radialGradient id="radar-grad" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#7C3AED" stop-opacity="0.55"/>
                <stop offset="100%" stop-color="#A855F7" stop-opacity="0.18"/>
              </radialGradient>
            </defs>
            <g id="holoRadarGrid"></g>
            <g id="holoRadarAxes"></g>
            <polygon class="radar-poly" id="holoRadarPoly" points=""/>
            <polygon class="radar-scan" id="holoRadarScan" points="60,50 60,12 60,50"/>
            <g id="holoRadarVtx"></g>
            <g id="holoRadarLabels"></g>
          </svg>
        </div>
      </div>
      <!-- 右：行业分布条形图 -->
      <div class="v3-holo-bars-stage">
        <div class="v3-holo-bars-h">
          <span>📊 行业·项目分布</span>
          <em id="holoBarsTotal">—</em>
        </div>
        <div id="holoBarsList"></div>
      </div>
    </div>
  </div>

  <!-- 3 类入口 · 公文卡片（紧凑单行 · 标题+计数+meta） -->
  <div class="v3-entries">
    <a class="v3-entry" href="page.html?view=cat&cat=在推重点" id="entryP0" style="--cat-color:#C0392B;--cat-color-2:#E67E22">
      <div class="v3-entry-row1">
        <div class="v3-entry-icon">🏛</div>
        <div class="v3-entry-title">在推重点</div>
        <div class="v3-entry-count"><span id="cntP0N">0</span><small>项</small></div>
      </div>
      <div class="v3-entry-meta" id="metaP0">载入中...</div>
      <div class="v3-entry-arrow">进入 →</div>
    </a>
    <a class="v3-entry" href="page.html?view=cat&cat=储备" id="entryP1" style="--cat-color:#1565C0;--cat-color-2:#0EA5E9">
      <div class="v3-entry-row1">
        <div class="v3-entry-icon">📂</div>
        <div class="v3-entry-title">储备</div>
        <div class="v3-entry-count"><span id="cntP1N">0</span><small>项</small></div>
      </div>
      <div class="v3-entry-meta" id="metaP1">载入中...</div>
      <div class="v3-entry-arrow">进入 →</div>
    </a>
    <a class="v3-entry" href="page.html?view=cat&cat=观察" id="entryP2" style="--cat-color:#6B7280;--cat-color-2:#9CA3AF">
      <div class="v3-entry-row1">
        <div class="v3-entry-icon">🔭</div>
        <div class="v3-entry-title">观察</div>
        <div class="v3-entry-count"><span id="cntP2N">0</span><small>项</small></div>
      </div>
      <div class="v3-entry-meta" id="metaP2">载入中...</div>
      <div class="v3-entry-arrow">进入 →</div>
    </a>
  </div>

  <!-- 近期动态时间线 · 填充页面空白 · 数据流 -->
  <div class="v3-timeline" id="timeline">
    <div class="v3-timeline-head">
      <h3>📡 近期动态 · 数据流</h3>
      <em id="timelineMeta">载入中...</em>
    </div>
    <div class="v3-timeline-track" id="timelineTrack">
      <div class="v3-feed-empty">载入中...</div>
    </div>
  </div>

  <!-- 行业分布 · 筛选条（点击标签联动右侧行业动态） -->
  <div class="v3-cloud-strip v3-hud">
    <span class="lbl">行业分布</span>
    <div class="v3-cloud-tags" id="cloudTags">
      <div class="v3-cloud-empty">载入中...</div>
    </div>
  </div>

  <!-- 双栏滚动流：行业最新动态 | 近期报告 -->
  <div class="v3-feed2">
    <!-- 左：行业最新动态 -->
    <div class="v3-feed v3-hud v3-corner" style="--feed-color:#C0392B">
      <div class="v3-feed-head">
        <h2>行业最新动态</h2>
        <small id="newsIndLabel">全部行业</small>
      </div>
      <div class="v3-marquee" id="newsMarquee">
        <div class="v3-marquee-track" id="newsTrack">
          <div class="v3-feed-empty">载入中...</div>
        </div>
      </div>
    </div>

    <!-- 右：近期报告 -->
    <div class="v3-feed v3-hud v3-corner" style="--feed-color:#1565C0">
      <div class="v3-feed-head">
        <h2>近期报告</h2>
        <small id="recentTotalLbl">载入中...</small>
      </div>
      <div class="v3-marquee" id="recentMarquee">
        <div class="v3-marquee-track" id="recentTrack">
          <div class="v3-feed-empty">载入中...</div>
        </div>
      </div>
    </div>
  </div>

</div>

<script src="assets/dnd.js"></script>
<script src="assets/cmdK.js"></script>
<script>
/* ==============================
 * 首页 v3 渲染器 · 视觉重设计版
 * ============================== */
(function(){
  'use strict';

  let PROJECTS = [];
  let REPORTS = [];
  let NEWS = [];
  let NEWS_BY_IND = {};
  let SELECTED_INDUSTRY = '__ALL__';

  function legacyRedirect(){
    const u = new URLSearchParams(location.search);
    const view = u.get('view');
    const cat = u.get('cat');
    const code = u.get('code');
    if (view === 'cat' && cat) {
      location.replace('page.html?' + u.toString());
      return true;
    }
    if (view === 'proj' && code) {
      location.replace('detail.html?code=' + encodeURIComponent(code));
      return true;
    }
    return false;
  }

  function v2to3Cat(cat){
    const map = {
      'deal': '在推重点','np': '储备','p': '储备',
      'kg': '观察','hub': '观察','course': '观察',
    };
    return map[cat] || '在推重点';
  }

  async function loadData(){
    try {
      const [p, r, n] = await Promise.all([
        fetch('data/projects.json', {cache:'no-store'}),
        fetch('data/reports.json', {cache:'no-store'}),
        fetch('data/industry_news.json', {cache:'no-store'}),
      ]);
      PROJECTS = (await p.json()).projects || [];
      REPORTS = (await r.json()).by_code || {};
      const newsRaw = (await n.json()) || {};
      NEWS_BY_IND = newsRaw.industries || {};
      NEWS = [];
      Object.entries(NEWS_BY_IND).forEach(([ind, items])=>{
        items.forEach(it=>NEWS.push({...it, industry:ind}));
      });
    } catch(e){
      console.error('数据加载失败', e);
      PROJECTS = []; REPORTS = {}; NEWS = []; NEWS_BY_IND = {};
    }
    window.PROJECTS = PROJECTS;
    window.REPORTS = REPORTS;
    if(window.cmdK) window.cmdK.rebuildIndex();
    renderAll();
  }

  /* ---------- KPI · 可视化 ---------- */
  const STAGE_COLORS = {'在推重点':'#C0392B','储备':'#1565C0','观察':'#6B7280'};
  const CAT_PALETTE = ['#1565C0','#C0392B','#0D8050','#7C3AED','#E67E22','#0EA5E9','#DC2626','#0891B2','#7C2D12','#1E3A8A','#166534','#B45309','#6D28D9','#BE185D'];

  function renderKPI(){
    /* ===== 数据计算 ===== */
    const allReports = Object.values(REPORTS).flat();
    const totalR = allReports.length;

    /* 行业（主+细分） */
    const mainIndMap = new Map();
    const subIndMap = new Map();
    PROJECTS.forEach(p=>{
      const inds = (p.industry||'').split(/[·\/ ]+/).map(t=>t.trim()).filter(Boolean);
      if(inds.length) mainIndMap.set(inds[0], (mainIndMap.get(inds[0])||0)+1);
      inds.forEach(t=>{ if(t!==inds[0]) subIndMap.set(t, (subIndMap.get(t)||0)+1); });
    });
    const industries = [...mainIndMap.entries()].sort((a,b)=>b[1]-a[1]);

    /* 平均进度（在推项目） */
    const activeProjects = PROJECTS.filter(p=>p.stage_v3==='在推重点');
    const avgProgress = activeProjects.length?
      Math.round(activeProjects.reduce((s,p)=>s+(p.progress_pct||0),0) / activeProjects.length) : 0;

    /* ===== 时间戳 ===== */
    const ts = new Date();
    const pad = n=>String(n).padStart(2,'0');
    const stamp = `${pad(ts.getHours())}:${pad(ts.getMinutes())}`;

    /* ===== 1. 顶部 4-指标数据条 ===== */
    document.getElementById('holoProjects').setAttribute('data-counter-up', PROJECTS.length);
    document.getElementById('holoReports').setAttribute('data-counter-up', totalR);
    document.getElementById('holoInds').setAttribute('data-counter-up', industries.length);
    document.getElementById('holoProgress').setAttribute('data-counter-up', avgProgress);

    /* ===== 2. RADAR · 行业分布（左侧主舞台） ===== */
    const IND_PALETTE = ['#7C3AED','#A855F7','#C0392B','#1565C0','#0EA5E9','#0D8050','#DC2626','#E67E22','#0891B2','#BE185D','#1E3A8A','#B45309'];
    /* 凑齐 ≥5 个数据点（雷达要有足够轴数）· 不足则补「—」占位 */
    const radarData = [...industries];
    while(radarData.length<5 && industries.length>0){
      radarData.push(['其他',0]);
    }
    const radarMax = Math.max(1, ...radarData.map(([_,c])=>c));
    const radarN = radarData.length;
    const radarCx = 60, radarCy = 50, radarR = 36;
    const radarAngles = radarData.map((_, i)=>(-Math.PI/2) + (i/radarN)*(Math.PI*2));

    /* Grid rings */
    const gridHtml = [0.33, 0.67, 1].map(scale=>{
      const pts = radarAngles.map(a=>`${(radarCx+radarR*scale*Math.cos(a)).toFixed(1)},${(radarCy+radarR*scale*Math.sin(a)).toFixed(1)}`).join(' ');
      return `<polygon class="radar-grid" points="${pts}" />`;
    }).join('');
    document.getElementById('holoRadarGrid').innerHTML = gridHtml;

    /* Axes */
    const axesHtml = radarAngles.map(a=>`<line class="radar-axis" x1="${radarCx}" y1="${radarCy}" x2="${(radarCx+radarR*Math.cos(a)).toFixed(1)}" y2="${(radarCy+radarR*Math.sin(a)).toFixed(1)}" />`).join('');
    document.getElementById('holoRadarAxes').innerHTML = axesHtml;

    /* Scan triangle · 从中心指向第一个轴 */
    const scanA0 = radarAngles[0];
    document.getElementById('holoRadarScan').setAttribute('points', `${radarCx},${radarCy} ${(radarCx+radarR*Math.cos(scanA0)).toFixed(1)},${(radarCy+radarR*Math.sin(scanA0)).toFixed(1)} ${radarCx},${radarCy}`);

    /* Data polygon */
    const polyPts = radarData.map(([_,v],i)=>{
      const a = radarAngles[i];
      const radius = (v/radarMax) * radarR;
      return `${(radarCx+radius*Math.cos(a)).toFixed(1)},${(radarCy+radius*Math.sin(a)).toFixed(1)}`;
    }).join(' ');
    document.getElementById('holoRadarPoly').setAttribute('points', polyPts);
    document.getElementById('holoRadarPoly').style.animation = 'radarPolyDraw 1.2s cubic-bezier(.4,.2,.2,1) forwards';

    /* Vertex rings (animated) */
    const vtxHtml = radarData.map(([_,v],i)=>{
      if(v===0) return '';
      const a = radarAngles[i];
      const radius = (v/radarMax) * radarR;
      const vx = radarCx + radius*Math.cos(a);
      const vy = radarCy + radius*Math.sin(a);
      return `<circle class="radar-vtx-ring" cx="${vx.toFixed(1)}" cy="${vy.toFixed(1)}" r="1.5" style="animation-delay:${i*200}ms"/>
              <circle class="radar-vtx" cx="${vx.toFixed(1)}" cy="${vy.toFixed(1)}" r="2.2" style="animation-delay:${300+i*150}ms"/>`;
    }).join('');
    document.getElementById('holoRadarVtx').innerHTML = vtxHtml;

    /* Labels (轴外标签) */
    const labelsHtml = radarData.map(([n,v],i)=>{
      const a = radarAngles[i];
      const lx = radarCx + (radarR+10) * Math.cos(a);
      const ly = radarCy + (radarR+10) * Math.sin(a);
      const anchor = (Math.cos(a)>0.3?'start':(Math.cos(a)<-0.3?'end':'middle'));
      return `<text class="radar-label" x="${lx.toFixed(1)}" y="${ly.toFixed(1)}" text-anchor="${anchor}" dominant-baseline="middle">${n}</text>`;
    }).join('');
    document.getElementById('holoRadarLabels').innerHTML = labelsHtml;

    document.getElementById('holoRadarTotal').textContent = `${industries.length} 行业 · ${PROJECTS.length} 项目`;

    /* ===== 3. 行业分布条形图（右侧主舞台） ===== */
    const topN = Math.min(8, industries.length);
    const barsListEl = document.getElementById('holoBarsList');
    const maxN = Math.max(1, ...industries.slice(0, topN).map(([_,c])=>c));
    barsListEl.innerHTML = industries.slice(0, topN).map(([n,c], i)=>{
      const col = IND_PALETTE[i % IND_PALETTE.length];
      const col2 = IND_PALETTE[(i+1) % IND_PALETTE.length];
      const w = (c / maxN * 100).toFixed(1);
      return `<div class="v3-holo-bar-row" title="${n}：${c} 个项目（占 ${(c/PROJECTS.length*100).toFixed(0)}%）">
        <span class="nm">${n}</span>
        <span class="bar"><i style="width:${w}%;--bc:${col};--bc-2:${col2};--bc-glow:${col}55"></i></span>
        <span class="cnt">${c}</span>
      </div>`;
    }).join('');
    document.getElementById('holoBarsTotal').textContent = `Top ${topN} · ${industries.length} 行业`;

    /* ===== 头部状态栏 ===== */
    const subCount = subIndMap.size;
    document.getElementById('holoMeta').innerHTML =
      `实时 ${stamp} · ${PROJECTS.length} 项目 · ${totalR} 报告 · ${industries.length} 行业` +
      (subCount?` <span style="color:var(--ink-3);font-weight:600">+${subCount}细分</span>`:'');

    /* === 3 类入口 === */
    renderEntries();

    /* 触发计数器动画 */
    if(window.cmdK) window.cmdK.counterUpAll();
  }

  /* CSS animations for donut sectors (keyframes via JS, avoid registering in CSS for legacy code) */
  (function(){
    if(document.getElementById('holoAnimStyle')) return;
    const s = document.createElement('style');
    s.id = 'holoAnimStyle';
    s.textContent = `
      @keyframes donutDraw{
        from{stroke-dasharray:0 var(--donut-c, ${(2*Math.PI*48).toFixed(2)})}
        to{stroke-dasharray:var(--donut-d,0) var(--donut-c,0)}
      }
      @keyframes radarPolyDraw{
        from{transform:scale(0);transform-origin:60px 50px;opacity:0}
        to{transform:scale(1);opacity:1}
      }
    `;
    document.head.appendChild(s);
  })();

  function renderEntries(){
    const groups = ['在推重点','储备','观察'];
    groups.forEach((s, gi)=>{
      const ps = PROJECTS.filter(p=>p.stage_v3===s);
      const cntN = ps.length;
      document.getElementById('cntP'+gi+'N').textContent = cntN;

      /* 进度估算（按当前 stage + 平均 progress_pct） */
      let pct;
      if(s==='在推重点'){
        pct = Math.min(100, Math.round(ps.reduce((sum,p)=>sum+(p.progress_pct||0),0) / Math.max(1, ps.length)));
      } else if(s==='储备'){
        pct = Math.min(100, Math.round(ps.reduce((sum,p)=>sum+((p.progress_pct||10)*0.7+15),0) / Math.max(1, ps.length)));
      } else {
        pct = Math.min(100, Math.round(ps.reduce((sum,p)=>sum+((p.progress_pct||5)*0.4+5),0) / Math.max(1, ps.length)));
      }

      /* 每个类别的简明 meta：进度% + 子统计 + Top 行业 */
      let subPart = '';
      if(gi===0){
        const l = ps.filter(p=>(p.progress_pct||0)>=30).length;
        const d = ps.filter(p=>(p.progress_pct||0)>=60).length;
        subPart = `<b>${l}</b>立项 <span class="sep">·</span> <b>${d}</b>已尽调`;
      } else if(gi===1){
        const u = ps.filter(p=>!p.iss || p.iss==='未上市' || (p.iss||'').includes('未')).length;
        subPart = `<b>${u}</b>未上市 <span class="sep">·</span> <b>${cntN-u}</b>上市/REITs`;
      } else {
        const short = ps.filter(p=>(p.progress_pct||0)<20).length;
        const mid   = ps.filter(p=>(p.progress_pct||0)>=20 && (p.progress_pct||0)<50).length;
        subPart = `<b>${short}</b>短链 <span class="sep">·</span> <b>${mid}</b>中链`;
      }

      /* Top 行业 chips 内联 */
      const indMap = new Map();
      ps.forEach(p=>{
        const main = (p.industry||'').split('·')[0].trim();
        if(main) indMap.set(main, (indMap.get(main)||0)+1);
      });
      const topInds = [...indMap.entries()].sort((a,b)=>b[1]-a[1]).slice(0,3);
      const chipPart = topInds.map(([n,c],i)=>
        `<span class="ind-chip"><i style="width:6px;height:6px;background:${CAT_PALETTE[i%CAT_PALETTE.length]};display:inline-block;border-radius:1px"></i>${n}<b>${c}</b></span>`
      ).join('') || '<span class="ind-chip" style="opacity:.5">—</span>';

      const metaHost = document.getElementById('metaP'+gi);
      if(metaHost){
        metaHost.innerHTML = `📊 ${pct}% <span class="sep">·</span> ${subPart} <span class="sep">·</span> ${chipPart}`;
      }
    });
  }

  /* ---------- 行业词云 ---------- */
  function aggregateIndustries(){
    const map = {};
    PROJECTS.forEach(p=>{
      const main = p.industry.split('·')[0].trim();
      if(!main) return;
      if(!map[main]) map[main] = {count:0, reports:0, samples:[]};
      map[main].count++;
      const rc = (REPORTS[p.code]||[]).length;
      map[main].reports += rc;
      if(map[main].samples.length<3) map[main].samples.push(p.name_cn);
    });
    return map;
  }
  function renderCloud(){
    const map = aggregateIndustries();
    const items = Object.entries(map).map(([k,v])=>({name:k,...v}));
    items.sort((a,b)=>b.count-a.count);
    const host = document.getElementById('cloudTags');
    if(!items.length){
      host.innerHTML = '<div class="v3-cloud-empty">暂无行业数据</div>';
      return;
    }
    const max = items[0].count;
    host.innerHTML = `
      <span class="v3-cloud-tag v3-cloud-tag-cloud${SELECTED_INDUSTRY==='__ALL__'?' active':''}" data-ind="__ALL__">
        全部行业 <span class="count">${items.length}</span>
      </span>
      ${items.map(it=>{
        return `<span class="v3-cloud-tag${SELECTED_INDUSTRY===it.name?' active':''}" data-ind="${it.name}">
          ${it.name} <span class="count">${it.count}</span>
        </span>`;
      }).join('')}
    `;
    host.querySelectorAll('.v3-cloud-tag').forEach(el=>{
      el.addEventListener('click',()=>{
        SELECTED_INDUSTRY = el.dataset.ind;
        renderCloud();
        renderNews();
        renderRecentTimeline();  /* 行业筛选也作用于近期报告 */
      });
    });
  }

  /* ---------- 行业动态 ---------- */
  function newsForIndustry(){
    if(SELECTED_INDUSTRY==='__ALL__') return NEWS;
    const keys = Object.keys(NEWS_BY_IND);
    const tokens = new Set([SELECTED_INDUSTRY]);
    PROJECTS.forEach(p=>{
      if((p.industry||'').split('·')[0].trim() === SELECTED_INDUSTRY){
        (p.industry||'').split(/[·\/ ]+/).forEach(t=>{ t=t.trim(); if(t) tokens.add(t); });
      }
    });
    const share2 = (a,b)=>{ for(let i=0;i+2<=a.length;i++){ if(b.includes(a.slice(i,i+2))) return true; } return false; };
    const matchedKeys = keys.filter(k=>{
      for(const t of tokens){ if(k===t || k.includes(t) || t.includes(k) || share2(t,k)) return true; }
      return false;
    });
    if(!matchedKeys.length) return [];
    const seen = new Set(), out = [];
    matchedKeys.forEach(k=>{
      NEWS_BY_IND[k].forEach(n=>{
        const id = (n.title||'')+'|'+(n.date||'');
        if(seen.has(id)) return; seen.add(id);
        out.push({...n, industry:k});
      });
    });
    return out;
  }
  function renderNews(){
    const data = newsForIndustry();
    const track = document.getElementById('newsTrack');
    const lbl  = document.getElementById('newsIndLabel');
    lbl.textContent = `${SELECTED_INDUSTRY==='__ALL__'?'全部行业':SELECTED_INDUSTRY} · ${data.length} 条`;
    if(!data.length){
      track.innerHTML = `<div class="v3-feed-empty">${SELECTED_INDUSTRY==='__ALL__'?'暂无行业动态':'该行业暂无公开动态 · 点「全部行业」查看'}</div>`;
      setMarquee('newsMarquee','newsTrack',0);
      return;
    }
    const cards = data.map(n=>`
      <a class="v3-feed-card" href="${n.url||'#'}" target="_blank" rel="noopener">
        <div class="v3-feed-card-top">
          <span class="v3-feed-tag">${escapeHtml(n.industry || n.source || '资讯')}</span>
          <span class="v3-feed-date">${n.date || ''}</span>
        </div>
        <div class="v3-feed-title">${escapeHtml(n.title || '')}</div>
      </a>
    `).join('');
    track.innerHTML = cards + cards;
    setMarquee('newsMarquee','newsTrack',data.length);
  }

  function setMarquee(marqueeId, trackId, count){
    const mq = document.getElementById(marqueeId);
    const track = document.getElementById(trackId);
    if(!mq || !track) return;
    requestAnimationFrame(()=>{
      const full = track.scrollHeight;
      const oneCopy = count > 0 ? full / 2 : full;
      if(count <= 0 || oneCopy <= mq.clientHeight + 4){
        mq.classList.add('no-scroll');
        track.style.removeProperty('--dur');
      } else {
        mq.classList.remove('no-scroll');
        const dur = Math.max(18, Math.round(oneCopy / 22));
        track.style.setProperty('--dur', dur + 's');
      }
    });
  }

  function tick(){
    const d=new Date();
    const pad=n=>String(n).padStart(2,'0');
    document.getElementById('navClock').textContent =
      `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
    document.getElementById('navDate').textContent =
      `${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日`;
  }

  function collectRecentReports(){
    const all = [];
    Object.entries(REPORTS).forEach(([code, list])=>{
      list.forEach(r=>all.push({...r, code}));
    });
    all.sort((a,b)=>b.date.localeCompare(a.date));
    /* 若选中了行业，则只保留该项目行业匹配的报告 */
    let filtered = all;
    let limit = 16;
    if(SELECTED_INDUSTRY && SELECTED_INDUSTRY !== '__ALL__'){
      filtered = all.filter(r=>{
        const proj = PROJECTS.find(p=>p.code===r.code);
        if(!proj) return false;
        const tokens = (proj.industry||'').split(/[·\/ ]+/).map(t=>t.trim()).filter(Boolean);
        return tokens.includes(SELECTED_INDUSTRY);
      });
      limit = 30;  // 筛选时放宽上限，让差异可见
    }
    return {list: filtered.slice(0, limit), total: filtered.length};
  }
  function renderRecentTimeline(){
    const {list, total} = collectRecentReports();
    const track = document.getElementById('recentTrack');
    const lbl  = document.getElementById('recentTotalLbl');
    const indLabel = SELECTED_INDUSTRY==='__ALL__' ? '全部 · 倒序' : `${SELECTED_INDUSTRY} · ${total} 份`;
    lbl.textContent = indLabel;
    if(!list.length){
      const msg = SELECTED_INDUSTRY==='__ALL__'
        ? '暂无研究报告 · 等待 research 代理推送'
        : `「${SELECTED_INDUSTRY}」暂无相关报告 · 点「全部行业」查看`;
      track.innerHTML = `<div class="v3-feed-empty">${msg}</div>`;
      setMarquee('recentMarquee','recentTrack',0);
      return;
    }
    const cards = list.map(r=>{
      const proj = PROJECTS.find(p=>p.code===r.code);
      const projName = proj ? (proj.name_cn || proj.code) : r.code;
      return `
        <a class="v3-feed-card" href="${r.url || ('detail.html?code='+encodeURIComponent(r.code))}" target="_blank" rel="noopener">
          <div class="v3-feed-card-top">
            <span class="v3-feed-tag">${escapeHtml(r.category || '未分类')}</span>
            <span class="v3-feed-date">${r.date || '—'}</span>
          </div>
          <div class="v3-feed-title">${escapeHtml(r.title || '(无标题)')}</div>
          <div class="v3-feed-sub">📁 ${escapeHtml(projName)}</div>
        </a>
      `;
    }).join('');
    track.innerHTML = cards + cards;
    setMarquee('recentMarquee','recentTrack',list.length);
  }

  function escapeHtml(s){return (s||'').replace(/[&<>"']/g,c=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));}

  function renderAll(){
    renderKPI();
    renderCloud();
    renderNews();
    renderRecentTimeline();
    renderTimeline();
    if(window.cmdK){
      window.cmdK.tiltAll();
    }
  }

  /* === 近期动态时间线 · 横向滚动 · 项目级里程碑 === */
  function renderTimeline(){
    const track = document.getElementById('timelineTrack');
    const meta  = document.getElementById('timelineMeta');
    if(!track) return;
    const STAGE_C = {'在推重点':'#C0392B', '储备':'#1565C0', '观察':'#6B7280'};
    /* 按 progress_pct 倒序 + 按更新时间聚合前 18 个项目 */
    const sorted = [...PROJECTS].sort((a,b)=>{
      const ap = a.progress_pct||0, bp = b.progress_pct||0;
      if(bp!==ap) return bp-ap;
      return (b.code||'').localeCompare(a.code||'');
    }).slice(0, 18);

    /* 计算每个项目最新报告日期（若存在） */
    const codeLatestReport = {};
    Object.entries(REPORTS).forEach(([code, list])=>{
      list.forEach(r=>{
        if(!codeLatestReport[code] || r.date > codeLatestReport[code]) codeLatestReport[code] = r.date;
      });
    });

    const cards = sorted.map(p=>{
      const c = STAGE_C[p.stage_v3] || '#6B7280';
      const rc = (REPORTS[p.code]||[]).length;
      const inds = (p.industry||'').split(/[·\/ ]+/).filter(Boolean);
      const indShort = inds[0] || '—';
      const lastReport = codeLatestReport[p.code] || '—';
      const pct = p.progress_pct || 0;
      const target = p.code==='acquisition-listed' ? 'detail.html?code=' + encodeURIComponent(p.code) : (p.folder ? `detail.html?code=${encodeURIComponent(p.code)}` : `page.html?view=cat&cat=${encodeURIComponent(p.stage_v3)}`);
      return `<a class="v3-tl-card" href="${target}" style="--tl-c:${c}" title="${p.name_cn||p.code}：进度 ${pct}%">
        <div class="v3-tl-top">
          <span style="color:${c}">${p.stage_v3}</span>
          <span style="font-family:ui-monospace,monospace">${pct}%</span>
        </div>
        <div class="v3-tl-stage">${escapeHtml(p.name_cn || p.code)}</div>
        <div class="v3-tl-meta">
          <i>${indShort}</i>
          <span>📄 <b>${rc}</b></span>
          <span>更新 <b>${lastReport}</b></span>
        </div>
      </a>`;
    }).join('');
    track.innerHTML = cards || '<div class="v3-feed-empty">暂无项目</div>';
    /* 横向自动轮播 · 每 30s 平滑滚动 1 张 */
    let offset = 0;
    setInterval(()=>{
      if(!track || track.children.length<3) return;
      offset += 220;
      if(offset > track.scrollWidth - track.clientWidth - 20) offset = 0;
      track.scrollTo({left:offset, behavior:'smooth'});
    }, 4000);
    if(meta){
      const updated = sorted.filter(p => codeLatestReport[p.code]).length;
      meta.innerHTML = `<b>${sorted.length}</b> 项目 · <b>${updated}</b> 有更新 · 自动轮播`;
    }
  }

  function bind(){
    let rz;
    window.addEventListener('resize', ()=>{
      clearTimeout(rz);
      rz = setTimeout(()=>{ renderNews(); renderRecentTimeline(); }, 200);
    });
  }

  function init(){
    if (legacyRedirect()) return;
    bind();
    tick(); setInterval(tick, 1000);
    loadData();
  }

  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
</body>
</html>
