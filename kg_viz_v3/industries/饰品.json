 "frameworks": [
  {
   "id": "fw_fw_0594672dadd2",
   "name": "政策受益型公司筛选框架",
   "type": "methodology",
   "category": "财务分析",
   "industry": "饰品",
   "steps": "[\"\\u8bc6\\u522b\\u5f71\\u54cd\\u884c\\u4e1a\\u683c\\u5c40\\u7684\\u5173\\u952e\\u653f\\u7b56\\u6587\\u4ef6\\u53ca\\u5176\\u6838\\u5fc3\\u6761\\u6b3e\", \"\\u5206\\u6790\\u653f\\u7b56\\u5bf9\\u4ea7\\u4e1a\\u94fe\\u5404\\u73af\\u8282\\u6210\\u672c\\u3001\\u5229\\u6da6\\u53ca\\u5e02\\u573a\\u96c6\\u4e2d\\u5ea6\\u7684\\u5f71\\u54cd\", \"\\u7b5b\\u9009\\u5177\\u5907\\u653f\\u7b56\\u7ea2\\u5229\\uff08\\u5982\\u6307\\u6807\\u3001\\u8d44\\u8d28\\uff09\\u6216\\u89c4\\u907f\\u653f\\u7b56\\u98ce\\u9669\\uff08\\u5982\\u6d77\\u5916\\u4ea7\\u80fd\\uff09\\u7684\\u4f01\\u4e1a\", \"\\u8bc4\\u4f30\\u76ee\\u6807\\u4f01\\u4e1a\\u7684\\u4e1a\\u7ee9\\u5f39\\u6027\\u53ca\\u4f30\\u503c\\u5408\\u7406\\u6027\"]",
   "confidence": 0.8,
   "content": "框架名称：政策受益型公司筛选框架\n描述：针对受政策影响显著的行业环节（如稀土冶炼、再生铜），识别拥有特定资质或产能布局优势的企业。通过分析政策壁垒（如指定企业冶炼分离权）、成本结构变化（加工费暴涨）及海外布局（美国铜材产能），筛选出业绩改善确定性高的标的，如海亮股份等。\n适用场景：有色金属产业链上下游企业投资价值评估\n核心维度：政策壁垒, 成本结构, 产能布局\n步骤：识别影响行业格局的关键政策文件及其核心条款, 分析政策对产业链各环节成本、利润及市场集中度的影响, 筛选具备政策红利（如指标、资质）或规避政策风险（如海外产能）的企业, 评估目标企业的业绩弹性及估值合理性",
   "is_core": true,
   "node_type": "framework"
  }
 ],
