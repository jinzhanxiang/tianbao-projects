    {name:'退出',key:'exit'},
  ];

  /* ---------- 视图切换 ---------- */
  function showView(name){
    document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
    document.getElementById('view-'+name).classList.add('active');
    document.getElementById('navBack').style.display =
      (name==='overview')?'none':'inline-block';
    window.scrollTo({top:0,behavior:'instant'});
  }

  /* ---------- URL 解析 + 路由 ---------- */
  function getParams(){
    const u=new URLSearchParams(location.search);
    return {view:u.get('view')||'overview',cat:u.get('cat'),code:u.get('code')};
  }
  function setView(view,extra={}){
    const u=new URLSearchParams(location.search);
    u.set('view',view);
    Object.entries(extra).forEach(([k,v])=>{
      if(v===null||v===undefined)u.delete(k);else u.set(k,v);
    });
    const qs=u.toString();
    history.replaceState(null,'','?'+qs);
    render();
  }

  /* ---------- 渲染：首页 ---------- */
  function renderOverview(){
    showView('overview');

    // Pipeline
    const flow=document.getElementById('pipelineFlow');
    flow.innerHTML=STAGES.map(s=>{
      // 各阶段项目数（从 PROJECTS 数据中聚合 · 见 Step 3）
      const cnt = (window.PROJECTS||[]).filter(p=>p.stage_key===s.key).length;
      return `<div class="pipe-step">
        <div class="pipe-step-name">${s.name}</div>
        <div class="pipe-step-count">${cnt}</div>
        <div class="pipe-step-sub">个项目</div>
      </div>`;
    }).join('');

    // 分类卡片
    const grid=document.getElementById('catGrid');
    grid.innerHTML=CATS.map(c=>{
      const realCount = (window.PROJECTS||[]).filter(p=>p.cat===c.id).length || c.count;
      return `<div class="cat-card" style="--cat-color:${c.color}" data-cat="${c.id}">
        <div class="cat-header">
          <div class="cat-icon" style="background:${c.bg}">
            <span class="cat-emoji">${c.emoji}</span>
          </div>
          <span class="cat-badge">${realCount} 个</span>
        </div>
        <div class="cat-name">${c.name}</div>
        <div class="cat-desc">${c.desc}</div>
        <div class="cat-stats">
          <div>
            <div class="cat-stat-num">${realCount}</div>
            <div class="cat-stat-lbl">项目数</div>
          </div>
          <div>
            <div class="cat-stat-num">—</div>
            <div class="cat-stat-lbl">点击查看</div>
          </div>
        </div>
      </div>`;
    }).join('');

    // 绑定点击事件
    grid.querySelectorAll('.cat-card').forEach(card=>{
      card.addEventListener('click',()=>{
        setView('cat',{cat:card.dataset.cat});
      });
    });
  }

  /* ---------- 渲染：分类详情 ---------- */
  function renderCat(catId){
    const cat=CATS.find(c=>c.id===catId);
    if(!cat){renderOverview();return}
    showView('cat');
    document.getElementById('catBreadcrumb').textContent='← 返回总览';
    document.getElementById('catBreadcrumb').onclick=()=>setView('overview');
    document.getElementById('catTitle').textContent=cat.name;
    const projs=(window.PROJECTS||[]).filter(p=>p.cat===cat.id);
    document.getElementById('catSub').innerHTML=
      `<span class="hero-tag">${cat.emoji} ${projs.length} 个项目</span>
       <span>${cat.desc}</span>`;

    // 项目卡片网格
    const wrap=document.getElementById('catProjects');
    if(projs.length===0){
      wrap.innerHTML=`<div class="kpi" style="grid-column:1/-1;text-align:center;color:var(--text-3);padding:40px">
        暂无项目数据
      </div>`;
      return;
    }
    wrap.innerHTML=`<div class="cat-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
      ${projs.map(p=>`
        <div class="cat-card" style="--cat-color:${cat.color}" data-code="${p.id}">
          <div class="cat-header">
            <div class="cat-icon" style="background:${cat.bg}">
              <span class="cat-emoji">${cat.emoji}</span>
            </div>
            <span class="cat-badge">${p.stage}</span>
          </div>
          <div class="cat-name">${p.name}</div>
          <div class="cat-desc">${p.full||p.name}</div>
          <div class="cat-stats">
            <div>
              <div class="cat-stat-num">${p.reports||0}</div>
              <div class="cat-stat-lbl">报告数</div>
            </div>
            <div>
              <div class="cat-stat-num">${p.online?'✅':'—'}</div>
              <div class="cat-stat-lbl">${p.online?'已部署':'未部署'}</div>
            </div>
          </div>
        </div>`).join('')}
    </div>`;

    // 绑定项目卡片点击
    wrap.querySelectorAll('.cat-card[data-code]').forEach(card=>{
      card.addEventListener('click',()=>{
        setView('proj',{code:card.dataset.code,cat:catId});
      });
    });
  }

  /* ---------- 渲染：项目详情 v2.2（含报告链接）---------- */
/* ===== v2.1 · 新版 renderProj（合并项目阶段 + 报告列表为单一时间线） ===== */
function renderProj(code){
  const p=(window.PROJECTS||[]).find(x=>x.id===code);
  if(!p){renderCat(getParams().cat||'deal');return}
  const cat=CATS.find(c=>c.id===p.cat);
  showView('proj');
  document.getElementById('projBreadcrumb').textContent='← 返回「'+(cat?cat.name:p.cat)+'」';
  document.getElementById('projBreadcrumb').onclick=()=>setView('cat',{cat:p.cat});
  document.getElementById('projTitle').textContent=p.full||p.name;
  document.getElementById('projSub').innerHTML=
    `<span class="hero-tag">${cat?cat.emoji:''} ${cat?cat.name:p.cat}</span>
     <span>${p.industry||'—'}</span>
     <span>${p.stage}</span>`;

  /* ---------- 1. KPI 4 卡（项目摘要） ---------- */
  const tl=p.report_timeline||[];
  const totalReports = tl.length || p.reports || 0;
  const firstDate = tl.length ? tl[tl.length-1].date : '—';  // offset 最大的 = 最早
  const lastDate  = tl.length ? tl[0].date : (p.deploy||'—'); // offset=0 = 最近
  const onlineBtn = p.url ? `
    <a href="${p.url}" target="_blank"
       style="display:inline-flex;align-items:center;gap:6px;
              padding:8px 16px;background:var(--navy);color:var(--gold);
              border-radius:8px;text-decoration:none;font-weight:600;font-size:13px">
      🔗 在线访问项目主页 →
    </a>` : '';

  const kpiSec = document.createElement('section');
  kpiSec.className = 'section';
  kpiSec.innerHTML = `
    <div class="kpi-grid" style="margin-bottom:0">
      <div class="kpi kpi-gold">
        <div class="kpi-label">报告总数</div>
        <div class="kpi-value">${totalReports}</div>
        <div class="kpi-sub">${tl.length>=1055?'含 1,055 实体':'按时间串联'}</div>
      </div>
      <div class="kpi kpi-blue">
        <div class="kpi-label">起止时间</div>
        <div class="kpi-value" style="font-size:18px">${firstDate}</div>
        <div class="kpi-sub">→ ${lastDate}</div>
      </div>
      <div class="kpi kpi-emerald">
        <div class="kpi-label">当前阶段</div>
        <div class="kpi-value" style="font-size:18px">${p.stage||'—'}</div>
        <div class="kpi-sub">${p.industry||'—'}</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">部署状态</div>
        <div class="kpi-value">${p.online?'✅':'—'}</div>
        <div class="kpi-sub">${p.online?'已部署':'未部署'}</div>
      </div>
    </div>
    ${onlineBtn ? '<div style="margin-top:16px">'+onlineBtn+'</div>' : ''}
  `;
  document.getElementById('projTimeline').replaceWith(kpiSec);
  // 给 KPI 段补一个 id（路由依赖）
  kpiSec.id = 'projTimeline';

  /* ---------- 2. 时间线主体（核心 · v2.1） ---------- */
  if(tl.length === 0){
    const empty = document.createElement('section');
    empty.className = 'section';
    empty.innerHTML = `<div class="pipeline-card">
      <div class="pipeline-title">📅 报告时间线</div>
      <div style="padding:40px;text-align:center;color:var(--text-3);font-size:14px">
        暂无报告时间数据
      </div>
    </div>`;
    document.getElementById('projReports').replaceWith(empty);
    empty.id = 'projReports';
    return;
  }

  // 时间线节点（按 offset 升序 = 最早 → 最新）
  const sorted = [...tl].sort((a,b) => a.date.localeCompare(b.date));
  const lastDateStr = sorted[sorted.length-1].date;
  const stageColor = {
    '重大并购': '#dc2626',
    '储备·非上市': '#2563eb',
    '储备·上市': '#7c3aed',
    '知识图谱': '#10b981',
    '中心·入口': '#f59e0b',
    '内训课件': '#0891b2',
  };
  const dotColor = cat ? (stageColor[cat.name] || '#06113A') : '#06113A';

  const nodes = sorted.map((t, idx) => {
    const isLast = idx === sorted.length - 1;
    const isFirst = idx === 0;
    return `
      <div style="display:flex;gap:16px;position:relative;${isLast?'':'padding-bottom:18px'}">
        <!-- 左侧：日期 + 圆点 + 连接线 -->
        <div style="flex-shrink:0;width:96px;text-align:right;position:relative">
          <div style="font-size:13px;font-weight:700;color:var(--navy);
                      font-variant-numeric:tabular-nums;margin-bottom:4px">
            ${t.date}
          </div>
          ${isLast ? `
            <div style="font-size:11px;color:var(--emerald);font-weight:700;
                        background:#ecfdf5;padding:2px 8px;border-radius:10px;
                        display:inline-block">
              📍 当前
            </div>` : ''}
        </div>
        <!-- 圆点 + 连接线 -->
        <div style="position:relative;width:24px;flex-shrink:0">
          <div style="position:absolute;left:9px;top:6px;bottom:-18px;
                      width:2px;background:${isLast?'var(--emerald)':'var(--border)'};
                      ${isLast?'display:none':''}">
          </div>
          <div style="position:relative;z-index:1;width:20px;height:20px;
                      border-radius:50%;background:${isLast?'var(--emerald)':dotColor};
                      border:3px solid #fff;
                      box-shadow:0 0 0 1px ${isLast?'var(--emerald)':dotColor};
                      margin-top:2px">
          </div>
        </div>
        <!-- 右侧：报告信息 -->
        <div style="flex:1;min-width:0;
                    background:${isLast?'#ecfdf5':'var(--card)'};
                    border:1px solid ${isLast?'var(--emerald)':'var(--border)'};
                    border-radius:var(--r);padding:12px 16px;
                    ${isLast?'box-shadow:0 2px 8px rgba(16,185,129,.15)':''}">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;
                      flex-wrap:wrap">
            <span style="font-size:11px;font-weight:700;
                         background:${dotColor};color:#fff;
                         padding:2px 10px;border-radius:10px">
              ${t.type}
            </span>
            <span style="font-size:11px;color:var(--text-3)">
              ${t.tag||''}
            </span>
            ${t.special ? `<span style="font-size:11px;color:var(--gold-2);
                            font-weight:700;background:#fffbeb;
                            padding:2px 10px;border-radius:10px">
              ${t.special}
            </span>` : ''}
          </div>
          <div style="font-size:14px;color:var(--text);
                      font-weight:${isLast?'700':'500'};margin-bottom:6px">
            <a href="${t.url||p.url||'#'}" target="_blank"
               style="color:${isLast?'var(--emerald)':'var(--navy)'};
                      text-decoration:none;
                      border-bottom:1px dashed ${isLast?'var(--emerald)':'var(--border)'};
                      padding-bottom:1px">
              ${t.title}
            </a>
            ${t.url ? `<span style="font-size:11px;color:var(--text-3);margin-left:8px">→</span>` : ''}
          </div>
          ${isLast && p.url ? `
            <div style="margin-top:4px;font-size:12px;color:var(--text-3)">
              <a href="${p.url}" target="_blank"
                 style="color:var(--navy);text-decoration:none;font-weight:600">
                📄 查看项目主页（${p.reports||0} 份完整报告）→
              </a>
            </div>` : ''}
          ${isFirst && p.dash ? `
            <div style="margin-top:4px;font-size:12px;color:var(--text-3)">
              <a href="${p.dash}" target="_blank"
                 style="color:var(--navy);text-decoration:none;font-weight:600">
                🗂️ 查看双视图时间线 →
              </a>
            </div>` : ''}
        </div>
      </div>`;
  }).join('');

  const tlCard = document.createElement('section');
  tlCard.className = 'section';
  tlCard.innerHTML = `
    <div class="pipeline-card">
      <div style="display:flex;align-items:center;justify-content:space-between;
                  margin-bottom:20px">
        <div class="pipeline-title" style="margin:0">
          📅 报告时间线 · ${sorted.length} 个节点
        </div>
        <div style="font-size:12px;color:var(--text-3);
                    font-variant-numeric:tabular-nums">
          ${sorted[0].date} → ${sorted[sorted.length-1].date}
        </div>
      </div>
      <div style="position:relative">
        ${nodes}
      </div>
    </div>
  `;
  document.getElementById('projReports').replaceWith(tlCard);
  tlCard.id = 'projReports';
}/* ---------- 主路由 ---------- */
  function render(){
    const p=getParams();
    if(p.view==='cat'&&p.cat) renderCat(p.cat);
    else if(p.view==='proj'&&p.code) renderProj(p.code);
    else renderOverview();
  }

  /* ---------- 初始化 ---------- */
  function init(){
    // 返回按钮
    document.getElementById('navBack').addEventListener('click',()=>{
      const p=getParams();
      if(p.view==='proj') setView('cat',{cat:p.cat});
      else setView('overview');
    });
    // 实时时钟
    function tick(){
      const d=new Date();
      const pad=n=>String(n).padStart(2,'0');
      document.getElementById('navClock').textContent=
        `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
    }
    tick();setInterval(tick,1000);
    // 首次渲染
    render();
    // 监听前进/后退
    window.addEventListener('popstate',render);
  }

  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',init);
  }else{
    init();
  }
})();
</script>
</body>
</html>