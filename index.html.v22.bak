<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
<title>天保控股项目指挥中心</title>
<style>
/* ===== 1. 边界控制（永不溢出） ===== */
:root{
  --navy:#06113A;
  --navy-2:#0d1f5c;
  --gold:#D4AF37;
  --gold-2:#B8941F;
  --blue:#2563eb;
  --emerald:#10b981;
  --amber:#f59e0b;
  --purple:#7c3aed;
  --red:#ef4444;
  --text:#0f172a;
  --text-2:#475569;
  --text-3:#94a3b8;
  --border:rgba(15,23,42,.08);
  --bg:#f4f6fb;
  --card:#ffffff;
  --r:12px;
  --r-lg:20px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;overflow-x:hidden}
body{
  font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100dvh;
  -webkit-font-smoothing:antialiased;
}
.container{
  max-width:1280px;
  margin:0 auto;
  padding:0 24px;
  width:100%;
}
.section{margin:24px 0}

/* ===== 2. 顶栏（64px） ===== */
.nav{
  position:sticky;top:0;z-index:100;
  height:64px;
  background:rgba(255,255,255,.85);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.nav-inner{
  max-width:1280px;
  margin:0 auto;
  padding:0 24px;
  height:64px;
  display:flex;align-items:center;justify-content:space-between;
  gap:24px;
}
.nav-brand{display:flex;align-items:center;gap:12px;font-weight:700;font-size:16px}
.nav-logo{
  width:36px;height:36px;border-radius:8px;
  background:linear-gradient(135deg,var(--navy),var(--navy-2));
  color:var(--gold);
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:18px;
}
.nav-meta{display:flex;align-items:center;gap:16px;font-size:13px;color:var(--text-2)}
.nav-clock{
  font-variant-numeric:tabular-nums;
  color:var(--navy);font-weight:600;
}
.nav-back{
  display:none;
  cursor:pointer;
  color:var(--navy);
  font-weight:600;
}

/* ===== 3. Hero（精简版 · 仅信息汇总） ===== */
.hero{
  padding:32px 0 24px;
  background:linear-gradient(180deg,#ffffff 0%,var(--bg) 100%);
}
.hero-title{
  font-size:28px;font-weight:800;color:var(--navy);
  margin-bottom:8px;letter-spacing:-0.5px;
}
.hero-sub{
  font-size:14px;color:var(--text-2);
  display:flex;align-items:center;gap:16px;flex-wrap:wrap;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:6px;
  padding:4px 12px;border-radius:20px;
  background:rgba(212,175,55,.1);
  color:var(--gold-2);
  font-size:12px;font-weight:600;
}

/* ===== 4. KPI 卡（4 个 · 不溢出） ===== */
.kpi-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:16px;
  margin-bottom:24px;
}
.kpi{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:20px;
  transition:all .2s;
}
.kpi:hover{box-shadow:0 8px 24px -8px rgba(6,17,58,.12);transform:translateY(-2px)}
.kpi-label{
  font-size:12px;color:var(--text-3);
  text-transform:uppercase;letter-spacing:.5px;
  margin-bottom:8px;font-weight:600;
}
.kpi-value{
  font-size:32px;font-weight:800;color:var(--navy);
  line-height:1;font-variant-numeric:tabular-nums;
}
.kpi-sub{
  font-size:12px;color:var(--text-2);
  margin-top:8px;
}
.kpi-gold .kpi-value{color:var(--gold-2)}
.kpi-blue .kpi-value{color:var(--blue)}
.kpi-emerald .kpi-value{color:var(--emerald)}

/* ===== 5. Pipeline（横向 6 阶段 · 100% 宽度不溢出） ===== */
.pipeline-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:24px;
}
.pipeline-title{
  font-size:13px;font-weight:700;color:var(--text-2);
  margin-bottom:16px;
  display:flex;align-items:center;gap:8px;
}
.pipeline-flow{
  display:flex;align-items:stretch;
  gap:4px;
  overflow-x:auto;
  padding-bottom:4px;
}
.pipe-step{
  flex:1;
  min-width:140px;
  background:linear-gradient(180deg,#f8fafc,#ffffff);
  border:1px solid var(--border);
  border-radius:var(--r);
  padding:14px 12px;
  position:relative;
}
.pipe-step::after{
  content:'›';
  position:absolute;right:-12px;top:50%;
  transform:translateY(-50%);
  color:var(--text-3);font-size:18px;font-weight:700;
  z-index:1;
}
.pipe-step:last-child::after{display:none}
.pipe-step-name{
  font-size:12px;font-weight:700;color:var(--navy);
  margin-bottom:6px;
}
.pipe-step-count{
  font-size:24px;font-weight:800;color:var(--gold-2);
  line-height:1;
  font-variant-numeric:tabular-nums;
}
.pipe-step-sub{
  font-size:11px;color:var(--text-3);
  margin-top:4px;
}

/* ===== 6. 分类卡片网格（首页 · 6 大分类 · 大卡） ===== */
.cat-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:16px;
}
.cat-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:24px;
  cursor:pointer;
  transition:all .2s;
  position:relative;
  overflow:hidden;
}
.cat-card::before{
  content:'';
  position:absolute;left:0;top:0;bottom:0;width:4px;
  background:var(--cat-color,var(--navy));
}
.cat-card:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 32px -8px rgba(6,17,58,.18);
}
.cat-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:16px;
}
.cat-icon{
  width:48px;height:48px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:24px;
  background:rgba(6,17,58,.06);
}
.cat-emoji{font-size:28px}
.cat-badge{
  background:var(--cat-color,var(--navy));
  color:#fff;
  padding:4px 10px;border-radius:20px;
  font-size:11px;font-weight:700;
  letter-spacing:.3px;
}
.cat-name{
  font-size:18px;font-weight:700;color:var(--navy);
  margin-bottom:6px;
}
.cat-desc{
  font-size:13px;color:var(--text-2);
  line-height:1.5;
  margin-bottom:16px;
}
.cat-stats{
  display:flex;gap:24px;
  padding-top:16px;
  border-top:1px solid var(--border);
}
.cat-stat-num{
  font-size:24px;font-weight:800;color:var(--cat-color,var(--navy));
  line-height:1;
}
.cat-stat-lbl{
  font-size:11px;color:var(--text-3);
  margin-top:4px;
}

/* ===== 7. 视图层切换（隐藏 / 显示） ===== */
.view{display:none}
.view.active{display:block}

/* 移动端适配 */
@media (max-width:768px){
  .container,.nav-inner{padding:0 16px}
  .hero-title{font-size:22px}
  .kpi-grid{grid-template-columns:repeat(2,1fr)}
  .cat-grid{grid-template-columns:1fr}
  .pipe-step{min-width:120px}
}
</style>
</head>
<body>
<!-- 顶栏 -->
<nav class="nav">
  <div class="nav-inner">
    <div class="nav-brand">
      <div class="nav-logo">保</div>
      <div>
        <div>天保控股</div>
        <div style="font-size:11px;color:var(--text-3);font-weight:400">项目指挥中心</div>
      </div>
    </div>
    <div class="nav-meta">
      <span class="nav-back" id="navBack">← 返回</span>
      <span class="nav-clock" id="navClock">--:--:--</span>
    </div>
  </div>
</nav>

<!-- ========== 视图 1: 首页 / 总览 ========== -->
<main class="view active" id="view-overview">
  <div class="hero">
    <div class="container">
      <h1 class="hero-title">项目指挥中心</h1>
      <div class="hero-sub">
        <span class="hero-tag">⭐ 信息汇总</span>
        <span>17 个项目 · 41+ 份报告 · 100% 部署</span>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- KPI 4 卡 -->
    <section class="section">
      <div class="kpi-grid">
        <div class="kpi kpi-gold">
          <div class="kpi-label">总项目数</div>
          <div class="kpi-value">17</div>
          <div class="kpi-sub">6 大分类</div>
        </div>
        <div class="kpi kpi-blue">
          <div class="kpi-label">报告总数</div>
          <div class="kpi-value">41+</div>
          <div class="kpi-sub">含 1,055 实体页</div>
        </div>
        <div class="kpi kpi-emerald">
          <div class="kpi-label">已部署</div>
          <div class="kpi-value">100%</div>
          <div class="kpi-sub">GitHub Pages</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">进行中</div>
          <div class="kpi-value">3</div>
          <div class="kpi-sub">并购 / 尽调</div>
        </div>
      </div>
    </section>

    <!-- Pipeline 6 阶段 -->
    <section class="section">
      <div class="pipeline-card">
        <div class="pipeline-title">📊 投资阶段漏斗</div>
        <div class="pipeline-flow" id="pipelineFlow">
          <!-- JS 注入 -->
        </div>
      </div>
    </section>

    <!-- 分类卡 6 个 -->
    <section class="section">
      <div style="font-size:13px;font-weight:700;color:var(--text-2);margin-bottom:16px">
        🗂️ 分类导航 · 点击进入
      </div>
      <div class="cat-grid" id="catGrid">
        <!-- JS 注入 -->
      </div>
    </section>

    <div style="height:48px"></div>
  </div>
</main>

<!-- ========== 视图 2: 分类详情 ========== -->
<main class="view" id="view-cat">
  <div class="hero">
    <div class="container">
      <div style="font-size:12px;color:var(--text-3);margin-bottom:6px" id="catBreadcrumb">← 返回总览</div>
      <h1 class="hero-title" id="catTitle">分类详情</h1>
      <div class="hero-sub" id="catSub"></div>
    </div>
  </div>
  <div class="container">
    <section class="section" id="catProjects">
      <!-- JS 注入该分类项目卡 -->
    </section>
    <div style="height:48px"></div>
  </div>
</main>

<!-- ========== 视图 3: 项目详情 ========== -->
<main class="view" id="view-proj">
  <div class="hero">
    <div class="container">
      <div style="font-size:12px;color:var(--text-3);margin-bottom:6px" id="projBreadcrumb">← 返回分类</div>
      <h1 class="hero-title" id="projTitle">项目详情</h1>
      <div class="hero-sub" id="projSub"></div>
    </div>
  </div>
  <div class="container">
    <section class="section" id="projTimeline">
      <!-- JS 注入时间线 -->
    </section>
    <section class="section" id="projReports">
      <!-- JS 注入报告列表 -->
    </section>
    <div style="height:48px"></div>
  </div>
</main>

<script>
